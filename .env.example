# Copy to `.env` (gitignored + vercelignored) and fill in the values you need.
# This file documents the ROOT workspace env (Rust SDK, examples, Foundry cuts,
# helper scripts). The credit proxy is a SEPARATE Vercel project with its own
# much larger env surface — see `proxy/.env.example`.
#
# Nothing here is bundled into the wasm app; the browser is BYOK / on-chain.

# ── LLM keys (examples + local backend smoke tests) ─────────────────────────
# examples/basic_agent.rs and scripts/probe-gemini.ps1 read GEMINI_API_KEY.
GEMINI_API_KEY=
# Optional: only if you exercise the Anthropic backend locally (BYOK).
ANTHROPIC_API_KEY=

# ── On-chain key (Foundry diamond cuts/deploys + live examples) ─────────────
# The diamond owner / deployer key. Foundry does NOT auto-load the root .env —
# scripts/release and manual `forge script` invocations load it explicitly.
# Live examples (tempo_tx_live.rs, soliditylite_*_e2e.rs, …) also read it.
# SENSITIVE: controls the deployed registry. Never commit a real value.
EVM_PRIVATE_KEY=

# ── Runtime toggles (optional) ──────────────────────────────────────────────
# CLI/SDK chain selection. Defaults to MAINNET; set `testnet` (or pass `--dev`)
# for the Moderato dev chain. Unrecognized values are a hard error.
LH_CHAIN=
# Stream idle-timeout override in ms (backends/stream_timeout.rs); default is fine.
LH_STREAM_IDLE_TIMEOUT_MS=
