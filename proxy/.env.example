# Credit proxy env (the SEPARATE Vercel "proxy" project — NOT shipped by the
# root release/web deploy). Copy to `proxy/.env` for `vercel dev`, or set these
# in the Vercel project settings for prod. Never commit real values.
#
# Only a few are required to boot; most are caps/toggles with safe defaults.
# Grouped by subsystem; see proxy/README.md for semantics.

# ── Chain (defaults baked in _chain.ts; override per environment) ────────────
TEMPO_RPC=
REGISTRY=            # diamond address
CHAIN_ID=
LH_TOKEN=            # $LH (LocalharnessCredits) address

# ── LLM providers (server-side keys for platform $LH path) ──────────────────
GEMINI_API_KEY=
GEMINI_API_KEYS=     # optional comma-separated rotation pool (takes priority)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Metering / pricing ──────────────────────────────────────────────────────
PROXY_METER_KEY=     # REQUIRED to debit the on-chain meter (meter-key role)
LH_METER_PAYEE=      # address credited by paid capabilities
COST_PER_REQUEST_WEI=        # flat per-request price (wei); see _prices.ts
MAX_COST_PER_REQUEST_WEI=    # ceiling for usage-based billing
LH_TOKEN_METERING=           # "1" = usage-based (token) billing; else flat
LH_MARGIN_BPS=               # platform margin on usage billing (basis points)
LH_MAX_OUTPUT_TOKENS=        # per-request output cap
LH_MAX_CREDITS_BODY_BYTES=   # request body size guard

# ── Web push (VAPID) ────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=       # mailto: or https: contact

# ── Scheduler (Vercel Cron no-tab job worker) ───────────────────────────────
CRON_SECRET=                       # gates the cron route
MCP_ASK_MODEL=                     # default model for scheduled/ask runs
SCHEDULER_GLOBAL_TICK_CAP_WEI=
SCHEDULER_PER_OWNER_TICK_CAP_WEI=
SCHEDULER_MAX_JOBS_PER_TICK=
SCHEDULER_MAX_PINGPONG_ROUNDS=
SCHEDULER_TICK_SOFT_BUDGET_MS=

# ── MCP-over-HTTP ───────────────────────────────────────────────────────────
MCP_DISCOVER_SCAN_CAP=
MCP_BOUNTY_LIST_CAP=

# ── Sponsor relay (mainnet keyless fee_payer; signs server-side) ────────────
LH_SPONSOR_KEY=                    # REQUIRED for the relay; the fee_payer root key
LH_RELAY_BALANCE_CEILING_WEI=
LH_RELAY_RATE_LIMIT=
LH_RELAY_RATE_WINDOW_MS=
LH_RELAY_GLOBAL_LIMIT=
LH_RELAY_MIN_FLOAT_WEI=

# ── Stripe fiat on-ramp (MintGateFacet) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
LH_MIN_USD_CENTS=
LH_MAX_USD_CENTS=
LH_CHECKOUT_SUCCESS_URL=
LH_CHECKOUT_CANCEL_URL=
LH_PEG_WEI_PER_USD_CENT=
FIAT_ISSUER_KEY=     # issuer-signed mintFromFiat key

# ── MPP on-ramp (USDC.e → $LH) ──────────────────────────────────────────────
ONRAMP_RPC=
ONRAMP_CHAIN_ID=
ONRAMP_USDCE=
ONRAMP_TREASURY=
ONRAMP_REGISTRY=
ONRAMP_SUBMITTER_KEY=
ONRAMP_MIN_CONFIRMATIONS=
MPP_MIN_LH=
MPP_MAX_LH=
MPP_RATE_PER_MIN=

# ── Telemetry (optional GitHub issue bridge) ────────────────────────────────
LH_TELEMETRY_REPO=
GH_TELEMETRY_TOKEN=
LH_TELEMETRY_RATE=

# ── App store (OFF-CHAIN cartridges → GitHub; api/publish.ts + api/app.ts) ───
# Where published cartridges live (one folder per agent: <name>/app.wasm + app.rl).
GH_APPSTORE_REPO=
# PAT with Contents:write on GH_APPSTORE_REPO. Falls back to GH_TELEMETRY_TOKEN
# when unset (so a single repo-scoped bot PAT, added as a push collaborator on the
# apps repo, serves both). Set this to a dedicated token to decouple the two.
GH_APPSTORE_TOKEN=
